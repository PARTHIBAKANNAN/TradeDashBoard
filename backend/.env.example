
# ============================================================================
# FYERS API v3 credentials — KEEP THESE SECRET. Never expose to the frontend.
# Copy this file to `.env` and fill in real values.
# ============================================================================

# App credentials from https://myapi.fyers.in/dashboard/
FYERS_CLIENT_ID=XXXXXX-100
FYERS_SECRET_KEY=YOURSECRETKEY

# Your login credentials (used only for the automated daily TOTP login flow)
FYERS_FY_ID=XY00000               # Your Fyers client / login ID
FYERS_USER_PIN=1234               # 4-digit trading PIN
FYERS_TOTP_SECRET=BASE32TOTPSEED  # The base32 seed from your authenticator app setup

# Must exactly match the redirect URL registered in the Fyers app dashboard
FYERS_REDIRECT_URI=https://127.0.0.1:8000/callback

# ---- App tuning (optional) ----
# Frontend origin(s) allowed by CORS, comma separated. In prod set to your https domain.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# SSE push cadence in seconds
STREAM_INTERVAL=1.0
# Set to "true" to force the data engine to run regardless of market hours (dev/testing)
FORCE_MARKET_OPEN=false

# ---- Server / hosting ----
# Bind address: 127.0.0.1 for local; 0.0.0.0 when hosted behind a reverse proxy (Caddy)
HOST=127.0.0.1
PORT=8000
# Only ONE instance may open the FYERS websocket. Set false on local dev so it never
# fights the hosted instance for the single allowed connection.
DATA_ENGINE_ENABLED=true
INSTANCE_NAME=local
# Absolute path to the built React app; leave unset to auto-detect ../frontend/dist
# FRONTEND_DIST=/opt/tradedash/frontend/dist
# Persist the token cache across restarts (mount a volume when containerized)
# TOKEN_CACHE_FILE=/data/.token_cache.json

# ---- Dashboard login (built-in; future: Razorpay subscriptions) ----
# Leave ADMIN_PASS empty to DISABLE the login gate (dev only).
ADMIN_USER=Admin
ADMIN_PASS=
# Random secret for signing session cookies — generate a long random string in prod.
SESSION_SECRET=change-me-to-a-long-random-string
